<Page x:Class="CinemaApp.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Вход" Background="#1a1a2e">

    <Grid>
        <Border Width="400" VerticalAlignment="Center" HorizontalAlignment="Center"
                Background="#16213e" CornerRadius="16" Padding="40">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.6" Color="#000000"/>
            </Border.Effect>
            <StackPanel>
                <!-- Заголовок -->
                <TextBlock Text="🎬 CinemaApp"
                           FontSize="22" FontWeight="Bold"
                           Foreground="#e94560"
                           HorizontalAlignment="Center" Margin="0,0,0,6"/>
                <TextBlock Text="Вход в аккаунт"
                           FontSize="16" Foreground="#a8a8b3"
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <!-- Логин -->
                <TextBlock Text="Логин" Foreground="#a8a8b3" FontSize="12" Margin="0,0,0,4"/>
                <Border Background="#1a1a2e" CornerRadius="8"
                        BorderBrush="#0f3460" BorderThickness="1" Margin="0,0,0,16">
                    <TextBox x:Name="LoginBox"
                             Background="Transparent" Foreground="White"
                             BorderThickness="0" Padding="12,10" FontSize="14"
                             CaretBrush="White"/>
                </Border>

                <!-- Пароль -->
                <TextBlock Text="Пароль" Foreground="#a8a8b3" FontSize="12" Margin="0,0,0,4"/>
                <Border Background="#1a1a2e" CornerRadius="8"
                        BorderBrush="#0f3460" BorderThickness="1" Margin="0,0,0,24">
                    <PasswordBox x:Name="PassBox"
                                 Background="Transparent" Foreground="White"
                                 BorderThickness="0" Padding="12,10" FontSize="14"
                                 CaretBrush="White"/>
                </Border>

                <!-- Сообщение об ошибке -->
                <TextBlock x:Name="ErrorText"
                           Foreground="#e94560" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,0,0,16"
                           Visibility="Collapsed" TextWrapping="Wrap"/>

                <!-- Кнопка входа -->
                <Button Content="Войти" Height="44" FontSize="15" FontWeight="SemiBold"
                        Cursor="Hand" Click="LoginBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="#e94560" CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#c73652"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Foreground>White</Button.Foreground>
                </Button>

                <!-- Ссылки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock Text="Нет аккаунта? " Foreground="#a8a8b3" FontSize="13"/>
                    <TextBlock Text="Зарегистрироваться"
                               Foreground="#e94560" FontSize="13"
                               Cursor="Hand" TextDecorations="Underline"
                               MouseLeftButtonUp="RegisterLink_Click"/>
                </StackPanel>

                <TextBlock Text="← Назад на главную"
                           Foreground="#a8a8b3" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,10,0,0"
                           Cursor="Hand"
                           MouseLeftButtonUp="BackLink_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
