<Page x:Class="CinemaApp.Pages.TicketPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Оформление билета" Background="#1a1a2e">

    <Grid>
        <Border Width="500" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>

                <!-- Заголовок -->
                <TextBlock Text="🎟 Оформление билета"
                           FontSize="24" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,6"/>
                <TextBlock Text="Проверьте данные перед оплатой"
                           FontSize="13" Foreground="#a8a8b3"
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <!-- Карточка билета -->
                <Border Background="#16213e" CornerRadius="16" Padding="30">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.5" Color="#000"/>
                    </Border.Effect>
                    <StackPanel>

                        <!-- Декоративная полоса -->
                        <Border Background="#e94560" Height="4" CornerRadius="2" Margin="0,0,0,24"/>

                        <!-- Строки билета -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🎬 Фильм" Foreground="#a8a8b3" FontSize="12"/>
                            <TextBlock x:Name="MovieNameText" Grid.Column="1"
                                       Foreground="White" FontSize="14" FontWeight="SemiBold"
                                       TextWrapping="Wrap" HorizontalAlignment="Right"/>
                        </Grid>

                        <Border Background="#0f3460" Height="1" Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="🏛 Зал" Foreground="#a8a8b3" FontSize="12"/>
                            <TextBlock x:Name="HallNameText" Grid.Column="1"
                                       Foreground="White" FontSize="14" FontWeight="SemiBold"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Border Background="#0f3460" Height="1" Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="📅 Дата и время" Foreground="#a8a8b3" FontSize="12"/>
                            <TextBlock x:Name="DateTimeText" Grid.Column="1"
                                       Foreground="White" FontSize="14" FontWeight="SemiBold"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Border Background="#0f3460" Height="1" Margin="0,0,0,14"/>

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="💺 Место" Foreground="#a8a8b3" FontSize="12"/>
                            <TextBlock x:Name="SeatText" Grid.Column="1"
                                       Foreground="White" FontSize="14" FontWeight="SemiBold"
                                       HorizontalAlignment="Right"/>
                        </Grid>

                        <Border Background="#0f3460" Height="1" Margin="0,0,0,20"/>

                        <!-- Итоговая цена -->
                        <Grid>
                            <TextBlock Text="Итого к оплате" Foreground="White"
                                       FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <TextBlock x:Name="TotalPriceText"
                                       Foreground="#e94560" FontSize="26" FontWeight="Bold"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Кнопки -->
                <Grid Margin="0,24,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Отмена -->
                    <Button Grid.Column="0" Content="← Отмена"
                            Height="48" FontSize="14" Cursor="Hand"
                            Click="CancelBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#0f3460" CornerRadius="8"
                                        Padding="16,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1a4a80"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>White</Button.Foreground>
                    </Button>

                    <!-- Подтвердить -->
                    <Button Grid.Column="2" Content="✔ Подтвердить"
                            Height="48" FontSize="14" Cursor="Hand"
                            Click="ConfirmBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#e94560" CornerRadius="8"
                                        Padding="16,0">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#c73652"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>White</Button.Foreground>
                        <Button.FontWeight>SemiBold</Button.FontWeight>
                    </Button>
                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</Page>
