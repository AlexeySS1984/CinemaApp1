<Page x:Class="CinemaApp.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Главная" Background="#1a1a2e">

    <Page.Resources>
        <!-- Кнопка-акцент -->
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Background"   Value="#e94560"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Padding"      Value="18,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#c73652"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Вторичная кнопка -->
        <Style x:Key="SecondBtn" TargetType="Button" BasedOn="{StaticResource AccentBtn}">
            <Setter Property="Background" Value="#0f3460"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1a4a80"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Карточка фильма -->
        <Style x:Key="MovieCard" TargetType="Border">
            <Setter Property="Background"       Value="#16213e"/>
            <Setter Property="CornerRadius"     Value="10"/>
            <Setter Property="Margin"           Value="8"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.4" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox тёмный -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"       Value="#16213e"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="BorderBrush"      Value="#0f3460"/>
            <Setter Property="Height"           Value="36"/>
            <Setter Property="Padding"          Value="8,4"/>
            <Setter Property="FontSize"         Value="13"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>  <!-- Header -->
            <RowDefinition Height="60"/>  <!-- Search + Sort -->
            <RowDefinition Height="*"/>   <!-- Movie Grid -->
        </Grid.RowDefinitions>

        <!-- ══════════ HEADER ══════════ -->
        <Border Grid.Row="0" Background="#0f3460">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="🎬 CinemaApp"
                               FontSize="24" FontWeight="Bold"
                               Foreground="White"/>
                </StackPanel>

                <!-- Кнопки в шапке -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="WelcomeText"
                               Foreground="#a8a8b3" FontSize="13"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button Content="👤 Личный кабинет"
                            Style="{StaticResource SecondBtn}"
                            Margin="0,0,10,0"
                            Click="ProfileBtn_Click"/>
                    <Button x:Name="LoginLogoutBtn"
                            Content="Войти"
                            Style="{StaticResource AccentBtn}"
                            Click="LoginLogoutBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════ ПАНЕЛЬ ПОИСКА И СОРТИРОВКИ ══════════ -->
        <Border Grid.Row="1" Background="#16213e" Padding="24,0">
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Поиск -->
                <Border Grid.Column="0" Background="#1a1a2e" CornerRadius="8"
                        BorderBrush="#0f3460" BorderThickness="1" Margin="0,0,16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" Margin="12,0,8,0"
                                   VerticalAlignment="Center" FontSize="14"/>
                        <TextBox x:Name="SearchBox"
                                 Grid.Column="1"
                                 Background="Transparent"
                                 Foreground="White"
                                 BorderThickness="0"
                                 VerticalAlignment="Center"
                                 FontSize="13"
                                 Padding="4,8"
                                 Text=""
                                 TextChanged="SearchBox_TextChanged">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TextBox">
                                                <Grid>
                                                    <TextBlock x:Name="Placeholder"
                                                               Text="Поиск фильмов..."
                                                               Foreground="#a8a8b3"
                                                               Margin="4,8"
                                                               IsHitTestVisible="False"
                                                               Visibility="Collapsed"/>
                                                    <ScrollViewer x:Name="PART_ContentHost"
                                                                  Margin="4,8"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="Text" Value="">
                                                        <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TextBox.Style>
                        </TextBox>
                    </Grid>
                </Border>

                <!-- Сортировка -->
                <TextBlock Grid.Column="1" Text="Сортировка:"
                           Foreground="#a8a8b3" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="SortCombo" Grid.Column="2"
                          Width="160"
                          SelectionChanged="SortCombo_SelectionChanged">
                    <ComboBoxItem Content="По умолчанию" IsSelected="True"/>
                    <ComboBoxItem Content="Название (А-Я)"/>
                    <ComboBoxItem Content="Название (Я-А)"/>
                    <ComboBoxItem Content="Рейтинг ↓"/>
                    <ComboBoxItem Content="Рейтинг ↑"/>
                </ComboBox>
            </Grid>
        </Border>

        <!-- ══════════ СЕТКА ФИЛЬМОВ ══════════ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" Padding="16">
            <ItemsControl x:Name="MoviesItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Карточка фильма -->
                        <Border Style="{StaticResource MovieCard}"
                                Width="200"
                                MouseLeftButtonUp="MovieCard_Click"
                                Tag="{Binding Id}">
                            <StackPanel>
                                <!-- Обложка -->
                                <Border CornerRadius="10,10,0,0" ClipToBounds="True" Height="280">
                                    <Grid Background="#0f3460">
                                        <!-- Заглушка когда нет постера -->
                                        <TextBlock Text="🎬" FontSize="48"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#a8a8b3"/>
                                        <!-- Постер загружается в code-behind через Tag -->
                                        <Image x:Name="PosterImg"
                                               Tag="{Binding CoverImage}"
                                               Stretch="UniformToFill"
                                               Loaded="PosterImg_Loaded"/>
                                    </Grid>
                                </Border>

                                <!-- Возрастной рейтинг поверх -->
                                <Grid Margin="8,-30,8,0">
                                    <Border Background="#e94560" CornerRadius="4"
                                            Padding="6,2" HorizontalAlignment="Right">
                                        <TextBlock Text="{Binding AgeRating}"
                                                   Foreground="White" FontSize="11"
                                                   FontWeight="Bold"/>
                                    </Border>
                                </Grid>

                                <!-- Информация -->
                                <StackPanel Margin="10,4,10,12">
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="White"
                                               FontSize="14" FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               MaxHeight="42"
                                               Margin="0,4,0,4"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="⭐ " Foreground="#f5c518" FontSize="13"/>
                                        <TextBlock Text="{Binding Rating}"
                                                   Foreground="#f5c518" FontSize="13"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <TextBlock Margin="0,4,0,0">
                                        <Run Text="С " Foreground="#a8a8b3" FontSize="11"/>
                                        <Run Text="{Binding StartDate, StringFormat=dd.MM.yyyy}"
                                             Foreground="#a8a8b3" FontSize="11"/>
                                    </TextBlock>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
