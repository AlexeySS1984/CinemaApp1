<Page x:Class="CinemaApp.Pages.ProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Личный кабинет" Background="#1a1a2e">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="40,30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ── Навигация ── -->
            <TextBlock Grid.Row="0" Text="← На главную"
                       Foreground="#a8a8b3" FontSize="13" Cursor="Hand"
                       Margin="0,0,0,24"
                       MouseLeftButtonUp="BackBtn_Click"/>

            <!-- ── Карточка пользователя ── -->
            <Border Grid.Row="1" Background="#16213e" CornerRadius="14"
                    Padding="28" Margin="0,0,0,28">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.4"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Аватар -->
                    <Border Grid.Column="0" Width="72" Height="72"
                            Background="#e94560" CornerRadius="36"
                            VerticalAlignment="Center" Margin="0,0,20,0">
                        <TextBlock x:Name="AvatarText"
                                   FontSize="28" FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Информация -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock x:Name="FullNameText"
                                   FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="LoginText"
                                   FontSize="13" Foreground="#a8a8b3" Margin="0,4,0,2"/>
                        <TextBlock x:Name="EmailText"
                                   FontSize="13" Foreground="#a8a8b3"/>
                    </StackPanel>

                    <!-- Выйти -->
                    <Button Grid.Column="2" Content="Выйти" VerticalAlignment="Center"
                            Cursor="Hand" Click="LogoutBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="#e94560" CornerRadius="8" Padding="16,8">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#c73652"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <Button.Foreground>White</Button.Foreground>
                        <Button.FontWeight>SemiBold</Button.FontWeight>
                    </Button>
                </Grid>
            </Border>

            <!-- ── Список билетов ── -->
            <StackPanel Grid.Row="2">
                <TextBlock Text="🎟 Мои билеты"
                           FontSize="20" FontWeight="Bold"
                           Foreground="White" Margin="0,0,0,16"/>

                <TextBlock x:Name="NoTicketsText"
                           Text="У вас пока нет купленных билетов."
                           Foreground="#a8a8b3" FontSize="14"
                           Visibility="Collapsed" Margin="0,0,0,12"/>

                <ItemsControl x:Name="TicketsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#16213e" CornerRadius="10"
                                    Padding="20,14" Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <!-- Название фильма -->
                                        <TextBlock Text="{Binding MovieTitle}"
                                                   FontSize="16" FontWeight="SemiBold"
                                                   Foreground="White" Margin="0,0,0,6"/>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock Text="📅 " Foreground="#a8a8b3" FontSize="12"/>
                                            <TextBlock Text="{Binding DateDisplay}"
                                                       Foreground="#a8a8b3" FontSize="12"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                            <TextBlock Text="🏛 " Foreground="#a8a8b3" FontSize="12"/>
                                            <TextBlock Text="{Binding HallDisplay}"
                                                       Foreground="#a8a8b3" FontSize="12"/>
                                        </StackPanel>

                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="💺 " Foreground="#a8a8b3" FontSize="12"/>
                                            <TextBlock Text="{Binding SeatDisplay}"
                                                       Foreground="#a8a8b3" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Цена + дата покупки -->
                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding PriceDisplay}"
                                                   Foreground="#e94560" FontSize="20"
                                                   FontWeight="Bold" HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding PurchaseDateDisplay}"
                                                   Foreground="#a8a8b3" FontSize="11"
                                                   HorizontalAlignment="Right" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>
